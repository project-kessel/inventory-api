{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "dockerfile": {
    "schedule": ["* 0-7 * * 0"]
  },
  "gomod": {
    "schedule": ["* 0-7 * * 0"],
    "packageRules": [
      {
        "matchManagers": ["gomod"],
        "matchPackageNames": ["github.com/go-kratos/**"],
        "matchUpdateTypes": ["major"],
        "enabled": false
      },
      {
        "matchDatasources": ["go"],
        "enabled": true,
        "groupName": "Go updates",
        "group": {
          "branchTopic": "go-updates",
          "commitMessageTopic": "go packages"
        }
      }
    ]
  }
}
